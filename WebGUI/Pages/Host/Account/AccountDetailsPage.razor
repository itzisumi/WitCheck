@page "/AccountDetailsPage"
@using WebGUI.DTOs
@using WebGUI.Pages.SharedLayouts
@inject NavigationManager nm
@inject Blazored.LocalStorage.ILocalStorageService localStorage
@using APICaller.API
@inject UserCaller uac
@inject LobbyCaller lac
<div class="account-details-page">
    <Sidebar />
@if (_user != null)
    {
        <div class="content">
            <h1 class="title">Account Details</h1>

            <div class="details-card">
                <div class="avatar">
                    @(_user.Firstname?.Length > 0 ? _user.Firstname[0].ToString().ToUpper() : "?")@(_user.Lastname?.Length > 0 ? _user.Lastname[0].ToString().ToUpper() : "")
                </div>

                <div class="info-section">
                    <div class="info-row">
                        <span class="info-label">Email</span>
                        <span class="info-value">@_user.Email</span>
                    </div>
                    <div class="divider"></div>
                    <div class="info-row">
                        <span class="info-label">First Name</span>
                        <span class="info-value">@_user.Firstname</span>
                    </div>
                    <div class="divider"></div>
                    <div class="info-row">
                        <span class="info-label">Last Name</span>
                        <span class="info-value">@_user.Lastname</span>
                    </div>
                    <div class="divider"></div>
                    <div class="info-row">
                        <span class="info-label">Username</span>
                        <span class="info-value">@_user.Username</span>
                    </div>
                </div>

                <div class="card-actions">
                    <button @onclick="ResetPasswordRedirect" class="btn btn-secondary">Reset Password</button>
                    <button @onclick="OpenSignOutDialog" class="btn btn-danger">Sign Out</button>
                </div>
            </div>

            <SignOutDialog
                IsOpen="@_signOutOpen"
                IsOpenChanged="@(v => _signOutOpen = v)"
                OnSignOutConfirmed="PerformSignOut" />
        </div>
    }

</div>


@code {
    private UserDTO _user;
    private bool _signOutOpen = false;
    protected override async Task OnInitializedAsync()
    {
        try
        {
            var user = await localStorage.GetItemAsync<int>("UserID");
            if (user != null)
            {
                _user = await uac.GetUserById(user);
                StateHasChanged();
            }
            else
            {
                throw new Exception("Not logged in before!");
            }
        }
        catch(Exception ex)
        {
        }
    }

    private async Task ResetPasswordRedirect()
    {
        nm.NavigateTo("/ResetPassword");
    }
    private void OpenSignOutDialog()
    {
        _signOutOpen = true;
    }

    private async Task PerformSignOut()
    {
        await localStorage.RemoveItemAsync("UserID");
        nm.NavigateTo("/LoginPage", true);
    }

}