@page "/lobby/{LobbyCode}/answers/host/mc"
@implements IDisposable
@using WebGUI.DTOs
@using APICaller.API
@using APICaller.Hub
@using Shared
@inject NavigationManager nm
@inject Blazored.LocalStorage.ILocalStorageService localStorage
@inject UserCaller uac
@inject LobbyCaller lac
@inject QuizCaller qc 
@inject HostHubCaller hostHub
@inject QuestionTimerService questionTimer

<div class="seeanswers-page">

    <div class="quiz-header" style="@GetQuizHeaderStyle()">
        <h1 class="quiz-title">@QuestionText</h1>
        <div class="timer">TIMER: @timeLeft s</div>
        <img src="images/Logo.png" alt="Logo" class="quiz-logo" />
    </div>

    <div class="line-wrapper">
        <hr class="divider" />
        <div class="playercount">
            ANSWERS:
        </div>
    </div>

    <div class="answers-grid">
        @for (var i = 0; i < Answers.Count; i++)
        {
            <div class="answer-box" style="background-color:@GetAnswerColor(i);">
                <span class="answer-letter">@((char)('A' + i))</span>
                <span class="answer-text">@Answers[i].Answer1</span>
            </div>
        }
    </div>

    <div class="footer">
        <button class="skip-btn" @onclick="SkipQuestion">SKIP</button>
    </div>
</div>

@code {
    [Parameter]
    public string LobbyCode { get; set; } = string.Empty;
    private UserDTO _user = default!;
    private string LobbyId = string.Empty;

    private QuizDTO quiz = new(0, "", 0, "#5BB933");
    private List<AnswerDTO> Answers = new();
    private IDisposable? _allPlayerFinishedSubscription;
    private string QuestionText = "Question";
    private bool _navigating;
    private int timeLeft = QuestionTimerService.DefaultSeconds;
    private static readonly string[] AnswerColors = ["#ff6b6b", "#4dabf7", "#ffd43b", "#51cf66"];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(LobbyCode))
            {
                nm.NavigateTo("/LoginPage", true);
                return;
            }

            LobbyId = LobbyCode;
            var user = await localStorage.GetItemAsync<int>("UserID");
            if (user != null)
            {
                _user = await uac.GetUserById(user);
            }
            else
            {
                throw new Exception("Not logged in before!");
            }

            await hostHub.StartHub();
            InitHubSubscriptions();
            questionTimer.Stop();
            questionTimer.Changed += HandleTimerChanged;
            questionTimer.Completed += HandleTimerCompleted;
            SyncTimeLeft();
            await LoadQuestionAndAnswersAsync();
        }
        catch (Exception ex)
        {
        }
    }

    private async Task LoadQuestionAndAnswersAsync()
    {
        LobbyId = LobbyCode;
        var question = await lac.GetQuestion(LobbyId)
                       ?? throw new Exception("Question not found");
        QuestionText = question.QuestionText;
        var countdownSeconds = question.Time > 0
            ? question.Time
            : QuestionTimerService.DefaultSeconds;

        var login = new LoginRequest(_user, await localStorage.GetItemAsync<string>("Password"));
        
        Answers = (await qc.GetAnswerByQuestionId(question.QuestionId, login))
                  ?.OrderBy(a => a.OrderNumber)
                  .ToList()
                  ?? new();
        
        quiz = await qc.GetQuiz(question.QuizId, login)
               ?? quiz;

        questionTimer.Start(countdownSeconds);
        SyncTimeLeft();
    }

    private void InitHubSubscriptions()
    {
        _allPlayerFinishedSubscription?.Dispose();
        _allPlayerFinishedSubscription = hostHub.AllPlayerFinished(async () =>
        {
            await HandleAllPlayersFinishedAsync();
        });
    }

    private async Task SkipQuestion()
    {
        if (_navigating)
            return;

        _navigating = true;
        var password = await localStorage.GetItemAsync<string>("Password") ?? string.Empty;
        await hostHub.AnswerTimeUp(new LoginRequest(_user, password),LobbyCode);
        nm.NavigateTo($"/lobby/{LobbyCode}/answers/host/mc/results");
    }

    private string GetQuizHeaderStyle()
    {
        var quizColor = quiz.ColorCode;
        return $"background-color:{quizColor};color:{QuizColorHelper.GetReadableTextColor(quizColor)};--quiz-header-text-shadow:{QuizColorHelper.GetReadableTextShadow(quizColor)};";
    }

    private void HandleTimerChanged()
    {
        SyncTimeLeft();
        _ = InvokeAsync(StateHasChanged);
    }

    private void HandleTimerCompleted()
    {
        _ = InvokeAsync(HandleQuestionTimeoutAsync);
    }

    private void SyncTimeLeft()
    {
        timeLeft = questionTimer.TimeLeft;
    }

    private async Task HandleAllPlayersFinishedAsync()
    {
        if (_navigating)
            return;

        _navigating = true;
        questionTimer.Stop();
        SyncTimeLeft();

        var password = await localStorage.GetItemAsync<string>("Password") ?? string.Empty;
        await hostHub.AnswerTimeUp(new LoginRequest(_user, password),LobbyCode);
        nm.NavigateTo($"/lobby/{LobbyCode}/answers/host/mc/results");
    }

    private async Task HandleQuestionTimeoutAsync()
    {
        if (_navigating)
            return;

        _navigating = true;
        questionTimer.Stop();
        SyncTimeLeft();

        var password = await localStorage.GetItemAsync<string>("Password") ?? string.Empty;
        await hostHub.AnswerTimeUp(new LoginRequest(_user, password),LobbyCode);
        nm.NavigateTo($"/lobby/{LobbyCode}/answers/host/mc/results");
    }
    
    private static string GetAnswerColor(int index) => AnswerColors[index % AnswerColors.Length];

    public void Dispose()
    {
        _allPlayerFinishedSubscription?.Dispose();
        questionTimer.Changed -= HandleTimerChanged;
        questionTimer.Completed -= HandleTimerCompleted;
        questionTimer.Stop();
    }
}

